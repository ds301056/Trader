# Copy this file to `.env` in the same folder and fill in your own values.
# `.env` is gitignored and must never be committed.

# OANDA practice account — https://www.oanda.com/ (Manage API Access)
OANDA_API_KEY=your-oanda-practice-api-key
OANDA_ACCOUNT_ID=your-oanda-account-id
OANDA_URL=https://api-fxpractice.oanda.com/v3

# MongoDB Atlas connection string — https://cloud.mongodb.com/
MONGO_CONN_STR=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority
